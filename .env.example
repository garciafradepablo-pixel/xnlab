# =============================================================================
# XNLAB — environment variables
#
# Copy to `.env.local` and fill in. NEVER commit real secrets — only this
# example is tracked. On Vercel, set these under Project → Settings →
# Environment Variables instead of a file.
# =============================================================================

# --- Email (Resend) ----------------------------------------------------------
# Powers every form on the site: /contact, /network, and Hunter Network
# (candidate applications + company enquiries). Without these, forms fall back
# to opening a mailto: draft — they never silently drop a submission.
RESEND_API_KEY=
RESEND_FROM="XNLAB <studio@xnlab.io>"   # must be a verified Resend sender
RESEND_TO=studio@xnlab.io               # where submissions land (optional)
# RESEND_TALENT_AUDIENCE_ID=            # optional Resend audience for /network

# --- Hunter Network · billing (Stripe) ---------------------------------------
# The Commercial Access Evaluation fee. It unlocks the EVALUATION only — never
# campaign access. NO amount is stored in the repo (house rule 5b): the price is
# a Stripe Price object, referenced here only by id.
#
# If STRIPE_SECRET_KEY or STRIPE_PRICE_ID is missing, billing runs on a stub
# that refuses (`billing_not_configured`) — nothing can charge a card. Leave
# these blank until billing is intentionally switched on.
STRIPE_SECRET_KEY=                      # sk_live_… or sk_test_…
STRIPE_PRICE_ID=                        # price_… for the access-evaluation fee
STRIPE_WEBHOOK_SECRET=                  # whsec_… from the Stripe webhook config
# Where Stripe sends the candidate after checkout (optional; sensible defaults
# derive from HN_PUBLIC_BASE_URL).
# STRIPE_SUCCESS_URL=https://xnlab.io/hunter-network?paid=1
# STRIPE_CANCEL_URL=https://xnlab.io/hunter-network?canceled=1

# --- Hunter Network · runtime ------------------------------------------------
# Public base URL, used to build absolute redirect/return URLs.
HN_PUBLIC_BASE_URL=https://xnlab.io
# Operations engine mode for the internal console (shadow = hidden virtual
# world, the safe default; live requires real integrations that don't exist yet
# and stays gated behind stub adapters).
HN_MODE=shadow
